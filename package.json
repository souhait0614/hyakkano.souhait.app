{
  "name": "hyakkano.souhait.app",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "waku dev",
    "build": "waku build",
    "start": "waku start",
    "deploy": "pnpm build --with-cloudflare && wrangler deploy",
    "lint": "concurrently --pad-prefix node:lint:*",
    "lint:typescript": "tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint .",
    "format": "eslint --fix . && stylelint --fix ."
  },
  "dependencies": {
    "@date-fns/tz": "1.4.1",
    "@tanstack/react-table": "8.21.3",
    "canvas-confetti": "1.9.4",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-server-dom-webpack": "19.2.6",
    "schummar-translate": "1.26.1",
    "tailwind-merge": "3.5.0",
    "tailwind-variants": "3.2.2",
    "valibot": "1.4.0",
    "waku": "0.27.5"
  },
  "devDependencies": {
    "@stylistic/stylelint-config": "5.0.0",
    "@tailwindcss/vite": "4.2.4",
    "@taiyme/eslint-config": "1.0.1",
    "@taiyme/vite-plugin-jsx-prune-classname": "0.0.3",
    "@types/canvas-confetti": "1.9.0",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.59.2",
    "concurrently": "9.2.1",
    "eslint": "10.3.0",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-plugin-better-tailwindcss": "4.5.0",
    "globals": "17.6.0",
    "jiti": "2.7.0",
    "kiso.css": "1.2.4",
    "lefthook": "2.1.6",
    "stylelint": "17.11.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-recommended": "18.0.0",
    "stylelint-config-tailwindcss": "1.0.1",
    "tailwindcss": "4.2.4",
    "terser": "5.47.1",
    "type-fest": "5.6.0",
    "typescript": "6.0.2",
    "vite": "7.3.3",
    "vite-tsconfig-paths": "6.1.1"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "overrides": {
      "vite": "$vite"
    },
    "patchedDependencies": {
      "waku": "patches/waku.patch"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "lefthook"
    ]
  }
}